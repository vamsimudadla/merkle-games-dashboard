NODE_ENV=development
PORT=8000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gamedb
DB_USER=gamedb_user
DB_PASSWORD=gamedb_pass

# JWT Secret
JWT_SECRET=your-secret-key-here-change-in-production

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# GraphQL
GRAPHQL_PATH=/graphql
GRAPHQL_PLAYGROUND=true